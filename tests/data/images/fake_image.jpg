# 1. 先生成一个正常的 1x1 红色 JPG (使用之前的 Base64)
$base64Jpg = ""
$bytes = [Convert]::FromBase64String($base64Jpg)

# 2. 截断数据：只保留前 50 个字节 (破坏文件结构)
$truncatedBytes = $bytes[0..49]

# 3. 保存为损坏的文件
$corruptedPath = Join-Path $PWD "corrupted_truncated.jpg"
[System.IO.File]::WriteAllBytes($corruptedPath, $truncatedBytes)

Write-Host "已生成截断损坏文件: $corruptedPath" -ForegroundColor Yellow